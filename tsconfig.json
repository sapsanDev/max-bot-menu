{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "nodenext",
        "isolatedModules": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "dist"
    ]
}